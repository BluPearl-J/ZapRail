# Server
PORT=4000
BASE_URL=http://localhost:4000

# Nomba API credentials
NOMBA_CLIENT_ID=your_client_id_here
NOMBA_PRIVATE_KEY=your_private_key_here
NOMBA_ACCOUNT_ID=your_account_id_here
NOMBA_API_BASE=https://sandbox.api.nomba.com/v1
NOMBA_WEBHOOK_SECRET=your_webhook_signing_secret_here

# Tunneling
NGROK_AUTHTOKEN=your_ngrok_token

# Monitoring & Alerting
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Security
INTERNAL_API_KEYS=replace_with_a_long_random_string